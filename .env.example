# Base de données PostgreSQL (Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://user:password@host:5432/localsud?sslmode=require"

# NextAuth — clé secrète à générer avec : openssl rand -base64 32
AUTH_SECRET="REMPLACE_PAR_UNE_CLE_LONGUE_GENEREE_OPENSSL_RAND_BASE64_32"
AUTH_URL="http://localhost:3000"

# Resend — pour l'envoi des emails (invitations, mdp oublié)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="LocalSud <noreply@localsud.fr>"

# Vercel Blob — stockage des PDF de factures et pièces jointes
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxx"

# Compte admin créé au seed (à modifier après le premier lancement)
ADMIN_EMAIL="sofiane@localsud.fr"
ADMIN_PASSWORD="ChangeMoiVite!2026"
ADMIN_NAME="Sofiane M."

# URL publique de l'app (pour les liens dans les emails)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
