generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ====== UTILISATEURS & AUTH ======

enum Role {
  ADMIN
  CLIENT
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?
  name          String
  role          Role     @default(CLIENT)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Lien vers la fiche client si role = CLIENT
  client        Client?

  // Tokens (création mdp, reset)
  tokens        AuthToken[]
}

// Tokens utilisés pour la création initiale du mot de passe et pour le reset
enum TokenType {
  SETUP   // création initiale (7 jours)
  RESET   // mot de passe oublié (1 heure)
}

model AuthToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  type      TokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ====== CLIENTS & PROJETS ======

model Client {
  id          String   @id @default(cuid())
  userId      String   @unique
  company     String   // Nom de l'entreprise / structure
  trade       String?  // Métier ("Restaurant", "Avocat", "Architecte"...)
  city        String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects    Project[]
}

enum ProjectStatus {
  BRIEF        // Brief reçu
  MAQUETTE     // Maquette en cours
  RETOURS      // En attente de retours / révisions
  INTEGRATION  // Intégration en cours
  ONLINE       // En ligne
  ARCHIVED     // Archivé
}

enum ProjectType {
  VITRINE      // Site vitrine
  LANDING      // Landing page
  ECOMMERCE    // E-commerce
  REFONTE      // Refonte
}

model Project {
  id            String         @id @default(cuid())
  clientId      String
  name          String
  type          ProjectType    @default(VITRINE)
  status        ProjectStatus  @default(BRIEF)

  // Liens des ressources visibles par le client
  mockupUrl     String?        // Lien de la maquette
  documentsUrl  String?        // Lien Drive des documents

  // Tarif total contractualisé
  totalPrice    Decimal        @default(0) @db.Decimal(10, 2)

  estimatedDelivery DateTime?
  deliveredAt   DateTime?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  payments      Payment[]
  comments      Comment[]
  steps         ProjectStep[]

  @@index([clientId])
  @@index([status])
}

// Étapes du projet (timeline visible côté client)
model ProjectStep {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  order       Int      @default(0)
  completed   Boolean  @default(false)
  completedAt DateTime?

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ====== FACTURATION ======

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
}

model Payment {
  id          String        @id @default(cuid())
  projectId   String
  label       String        // "Acompte 30%", "Solde", etc.
  amount      Decimal       @db.Decimal(10, 2)
  status      PaymentStatus @default(PENDING)
  dueDate     DateTime?
  paidAt      DateTime?
  invoiceRef  String?       // Référence facture type "LS-2026-014"

  // PDF de la facture (Vercel Blob)
  pdfUrl      String?
  pdfName     String?
  pdfSize     Int?

  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

// ====== RETOURS & COMMENTAIRES ======

enum CommentType {
  MODIFICATION
  QUESTION
  VALIDATION
  IDEA
}

enum CommentStatus {
  OPEN          // À traiter
  IN_PROGRESS   // En cours
  RESOLVED      // Résolu
}

model Comment {
  id          String        @id @default(cuid())
  projectId   String
  authorId    String        // User qui a posté (client OU admin)
  parentId    String?       // Pour les réponses (thread)

  type        CommentType   @default(MODIFICATION)
  status      CommentStatus @default(OPEN)
  section     String        // Page concernée (champ libre obligatoire)
  content     String        @db.Text

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent      Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[]     @relation("CommentReplies")
  attachments Attachment[]

  @@index([projectId])
  @@index([status])
  @@index([parentId])
}

// Pièces jointes (images, PDF, etc.) sur les commentaires
model Attachment {
  id          String   @id @default(cuid())
  commentId   String
  url         String   // URL Vercel Blob
  name        String
  size        Int
  mimeType    String
  isImage     Boolean  @default(false)
  createdAt   DateTime @default(now())

  comment     Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
}
